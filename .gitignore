# ── Dependencies ────────────────────────────────────────────
node_modules/
client/node_modules/
server/node_modules/

# ── Environment / secrets ────────────────────────────────────
.env
.env.*
server/.env
client/.env
!.env.example
!server/.env.example
!client/.env.example

# ── Build output ─────────────────────────────────────────────
client/build/
client/dist/
server/dist/

# ── Uploads (user-generated content, keep folder structure) ──
server/uploads/*
!server/uploads/.gitkeep

# ── Logs ────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ─────────────────────────────────────────────────────
*.pem
.npm
.yarn-integrity
